ORCH_GPU_DEVICES=1,2,3,4,5,6,7
ORCH_CARLA_IMAGE=carlasim/carla:0.9.16-phase3
ORCH_CARLA_CONTAINER_PREFIX=carla-orch
ORCH_CARLA_STARTUP_TIMEOUT=90
ORCH_CARLA_RPC_PORT_BASE=18467
ORCH_TRAFFIC_MANAGER_PORT_BASE=19467
ORCH_PORT_STRIDE=37
ORCH_CARLA_TIMEOUT=20
ORCH_METADATA_SLOT_INDEX=6
ORCH_CARLA_METADATA_HOST=127.0.0.1
ORCH_CARLA_METADATA_TIMEOUT=20
ORCH_DOCKER_NETWORK_MODE=host
ORCH_CARLA_START_COMMAND=./CarlaUE4.sh -RenderOffScreen -nosound -carla-rpc-port={rpc_port}
ORCH_STORAGE_BUCKET=simcloud-assets-public-test
ORCH_STORAGE_REGION=us-east-1
ORCH_STORAGE_PREFIX=runs
